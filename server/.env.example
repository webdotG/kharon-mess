# Максимум сообщений в секунду с одного соединения (token bucket)
# Человек физически не может быстрее 3/сек — всё что быстрее считается ботом
MSG_RATE_LIMIT=3
MSG_BUCKET_MAX=9

# Время жизни сообщения в миллисекундах (по умолчанию 2 минуты)
MSG_TTL_MS=120000

# Как часто sweep чистит протухшие сообщения (по умолчанию 30 сек)
SWEEP_INTERVAL_MS=30000

# Максимальный размер зашифрованного payload в байтах
MAX_MSG_SIZE=4096

# Максимум сообщений в офлайн-очереди одного пользователя
MAX_QUEUE_PER_USER=50

# Максимум одновременных соединений с одного IP (на уровне приложения)
MAX_CONNS_PER_IP=3

# Пути к TLS сертификатам
# Let's Encrypt: /etc/letsencrypt/live/yourdomain.com/fullchain.pem
# Самоподписанный для теста: ./certs/fullchain.pem
CERT_PATH=./certs/fullchain.pem
KEY_PATH=./certs/privkey.pem

# Максимум уникальных одновременных пользователей
MAX_CLIENTS=100
